# Auto-detect text vs binary; normalize to LF across all platforms
* text=auto eol=lf

# Source code — LF
*.py          text eol=lf
*.ts          text eol=lf
*.tsx         text eol=lf
*.json        text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.md          text eol=lf
*.css         text eol=lf
*.html        text eol=lf
*.sh          text eol=lf
*.toml        text eol=lf
*.ini         text eol=lf
*.cfg         text eol=lf
*.env.example text eol=lf
Dockerfile    text eol=lf

# Windows scripts — CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Lock files — generated, diff noise
package-lock.json linguist-generated
pnpm-lock.yaml   linguist-generated
*.lock           binary

# Archives & binaries — diff as binary
*.gz    binary
*.zip   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.eot   binary
*.ttf   binary
*.otf   binary

# Python generated
__pycache__/** linguist-generated
*.pyc           binary
*.pyo           binary
*.egg-info/**   linguist-generated
*.egg           binary

# Node generated
node_modules/** linguist-generated
.next/**        linguist-generated
dist/**         linguist-generated

# Database / IDE
*.db       binary
*.sqlite   binary
*.sqlite3  binary
.idea/**   linguist-generated
.vscode/** linguist-generated

# Environment (never commit)
.env linguist-generated

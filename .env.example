# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/devsquad

# JWT
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI Providers
GEMINI_API_KEY=

# Application
APP_NAME=DevSquad AI
APP_ENV=development
DEBUG=true

# CORS
CORS_ORIGINS=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=price_pro
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise

# Logging
LOG_LEVEL=INFO
